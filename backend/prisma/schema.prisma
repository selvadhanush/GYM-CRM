datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Gym {
  id                            String   @id @default(uuid())
  name                          String
  address                       String?
  phone                         String?
  email                         String?
  status                        String   @default("Active")
  images                        String[] @default([])
  // Per-gym default session duration (minutes). Controls how long a FitPrime
  // session stays active before auto-closing. Default 2 hours.
  defaultSessionDurationMinutes Int      @default(120)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
  settings                      GymSettings?

  @@index([status])
}

model GymSettings {
  id              String   @id @default(uuid())
  gymId           String   @unique
  gym             Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  
  // Branding
  gymName         String   @default("GYM CRM PRO")
  tagline         String   @default("Elevate Your Fitness Operations")
  logoUrl         String   @default("https://images.unsplash.com/photo-1517838277536-f5f99be501cd?w=80&auto=format&fit=crop&q=60")
  brandTheme      String   @default("dark")
  
  // Operations
  sessionDuration Int      @default(120)
  scanCooldown    Int      @default(300)
  qrRefreshRate   Int      @default(15)
  checkInSound    Boolean  @default(true)
  
  // Finance
  currency        String   @default("INR")
  taxRate         Float    @default(18)
  taxId           String   @default("27AAAAA1111A1Z1")
  razorpayEnabled Boolean  @default(true)
  razorpayKey     String   @default("rzp_test_xxxxxxxxx")
  
  // Notifications
  emailAlerts     Boolean  @default(true)
  smsAlerts       Boolean  @default(false)
  pushAlerts      Boolean  @default(true)
  
  // Business Hours (Stored as JSON string)
  hours           String   @default("{\"weekday\":\"06:00 AM - 10:00 PM\",\"saturday\":\"07:00 AM - 08:00 PM\",\"sunday\":\"08:00 AM - 02:00 PM\"}")

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([gymId])
}

model User {
  id                  String    @id @default(uuid())
  name                String
  email               String    @unique
  password            String
  phone               String?
  role                String    @default("admin")
  gymId               String
  memberId            String?
  isVerified          Boolean   @default(false)
  status              String    @default("Active")
  isActive            Boolean   @default(true)
  lastLogin           DateTime?
  // --- Web login brute-force protection (email+password login) ---
  failedLoginAttempts Int       @default(0)
  // Account is locked (cannot login) until this timestamp passes. Null = not locked.
  lockUntil           DateTime?
  branchId            String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([gymId])
  @@index([role])
}

model Plan {
  id             String   @id @default(uuid())
  name           String
  duration       Int      // duration value (used by traditional gym membership plans)
  durationUnit   String   @default("days") // e.g. "days", "hours" (traditional plans)
  // FitPrime (SYSTEM) plans grant a number of sessions instead of a time-based duration.
  // Null/0 for traditional plans; set only on FitPrime global plans.
  sessions       Int?
  price          Float
  gymId          String
  branchId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([gymId])
}

model Member {
  id                    String   @id @default(uuid())
  name                  String
  phone                 String
  email                 String?
  planId                String
  joinDate              DateTime @default(now())
  expiryDate            DateTime
  status                String   @default("Active")
  planPrice             Float    @default(0)
  paidAmount            Float    @default(0)
  gymId                 String
  branchId              String?
  freezeHistory         String?  // stored as JSON string
  // --- FitPrime session-based check-in fields ---
  // Live session credit counter for FitPrime (SYSTEM) plan holders.
  sessionsRemaining     Int      @default(0)
  // Original session count granted by the purchased FitPrime plan (reference/audit).
  sessionsTotal         Int      @default(0)
  // Timestamp of the last successful QR scan (drives analytics/history).
  lastCheckInAt         DateTime?
  // When the currently-active session auto-expires (startedAt + gym.defaultSessionDurationMinutes).
  // Null when no session is active. Authoritative gate for the "active session → 409" check.
  currentSessionEndsAt  DateTime?
  // The gym whose QR was scanned for the active session.
  currentSessionGymId   String?
  // Cooldown gate (authoritative): now < cooldownEndsAt → 429. Equals sessionEndsAt + 3h.
  cooldownEndsAt        DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([gymId])
  @@index([status])
  @@index([expiryDate])
  @@index([phone])
  @@index([planId])
}

model Attendance {
  id          String   @id @default(uuid())
  memberId    String
  date        DateTime @default(now())
  checkInTime String
  gymId       String
  branchId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([gymId, date])
  @@index([memberId])
}

// Audit-grade record of every FitPrime QR scan / session start.
// One row per successful check-in. Status moves active → expired via cron/lazy expiry.
model SessionCheckIn {
  id         String   @id @default(uuid())
  memberId   String
  gymId      String                      // the gym whose QR was scanned
  gymName    String   @default("")
  branchId   String?
  branchName String   @default("")
  startedAt  DateTime @default(now())
  expiresAt  DateTime                    // startedAt + gym.defaultSessionDurationMinutes
  status     String   @default("active") // "active" | "expired"
  createdAt  DateTime @default(now())

  @@index([gymId, status])
  @@index([gymId, startedAt])
  @@index([memberId])
}

model FitPassAuditLog {
  id                     String   @id @default(uuid())
  memberId               String
  memberName             String
  fitPassMembershipId    String
  organizationId         String
  branchId               String?
  gymIdVisited           String
  gymName                String
  branchIdVisited        String?
  branchNameVisited      String?
  checkInTimestamp       DateTime @default(now())
  accessStatus           String
  failureReason          String?
  totalPurchasedSessions Int
  sessionsUsedBefore     Int
  sessionsDeducted       Int
  remainingSessionsAfter Int
  membershipExpiryDate   DateTime
  qrCodeUsed             String
  deviceInfo             String?
  createdBySystem        Boolean  @default(true)
  createdAt              DateTime @default(now())

  @@index([memberId])
  @@index([gymIdVisited])
  @@index([accessStatus])
  @@index([createdAt])
}


model Payment {
  id            String   @id @default(uuid())
  memberId      String
  amount        Float
  method        String
  date          DateTime @default(now())
  gymId         String
  branchId      String?
  transactionId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([gymId, date])
  @@index([memberId])
}

model Expense {
  id          String   @id @default(uuid())
  gymId       String
  title       String
  amount      Float
  category    String
  date        DateTime @default(now())
  description String?
  branchId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([gymId, date])
}

model GymClass {
  id           String   @id @default(uuid())
  name         String
  type         String
  description  String   @default("")
  trainerName  String   @default("")
  scheduleDate DateTime
  startTime    String
  endTime      String
  maxSeats     Int      @default(10)
  gymId        String
  branchId     String?
  bookings     String?  // stored as JSON string
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([gymId, scheduleDate])
}

model Lead {
  id                String    @id @default(uuid())
  name              String
  phone             String
  email             String    @default("")
  source            String    @default("Walk-in")
  status            String    @default("New")
  interestedPlan    String    @default("")
  notes             String    @default("")
  followUpDate      DateTime?
  convertedMemberId String?
  gymId             String
  branchId          String?
  assignedTo        String    @default("")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([gymId, status])
  @@index([phone])
}

model AuditLog {
  id         String   @id @default(uuid())
  gymId      String
  userId     String?
  userName   String   @default("System")
  userEmail  String   @default("")
  userRole   String   @default("")
  action     String
  entity     String   @default("")
  entityId   String   @default("")
  entityName String   @default("")
  details    String   @default("")
  ip         String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([gymId, action])
  @@index([createdAt])
}

model Branch {
  id             String   @id @default(uuid())
  name           String
  address        String   @default("")
  phone          String   @default("")
  email          String   @default("")
  gymId          String
  managerId      String?
  managerName    String   @default("")
  isActive       Boolean  @default(true)
  fitPassEnabled Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([gymId])
}

model Notification {
  id          String   @id @default(uuid())
  recipientId String
  gymId       String
  type        String
  message     String
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([recipientId, read])
  @@index([gymId])
}

model OTP {
  id        String   @id @default(uuid())
  email     String   @unique
  otp       String
  expiresAt DateTime
  // Number of failed verification attempts for this OTP. After MAX_OTP_ATTEMPTS
  // (see authController) the OTP is invalidated and the user must request a new one.
  attempts  Int      @default(0)
  createdAt DateTime @default(now())
}

model MemberTrainerAssignment {
  id           String   @id @default(uuid())
  memberId     String
  trainerId    String
  assignedDate DateTime @default(now())
  gymId        String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WorkoutTemplate {
  id           String   @id @default(uuid())
  name         String
  description  String?
  exercises    String?
  gymId        String
  branchId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model WorkoutPlan {
  id           String   @id @default(uuid())
  memberId     String
  trainerId    String?
  name         String
  startDate    DateTime?
  endDate      DateTime?
  exercises    String?
  gymId        String
  branchId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model DietPlan {
  id           String   @id @default(uuid())
  memberId     String
  trainerId    String?
  name         String
  startDate    DateTime?
  endDate      DateTime?
  meals        String?
  gymId        String
  branchId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PtPackage {
  id           String   @id @default(uuid())
  name         String
  description  String?
  price        Float
  sessionCount Int
  duration     Int?
  gymId        String
  branchId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model PtSession {
  id           String   @id @default(uuid())
  memberId     String
  trainerId    String
  packageId    String?
  sessionDate  DateTime
  status       String   @default("Scheduled")
  notes        String?
  gymId        String
  branchId     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BodyAssessment {
  id             String   @id @default(uuid())
  memberId       String
  trainerId      String?
  weight         Float
  bmi            Float
  bodyFat        Float    // PBF
  muscleMass     Float    // SMM
  bmr            Float
  inBodyScore    Float?
  assessmentDate DateTime @default(now())
  gymId          String
  branchId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TrainerAttendance {
  id           String    @id @default(uuid())
  trainerId    String
  date         DateTime  @default(now())
  checkInTime  DateTime  @default(now())
  checkOutTime DateTime?
  workingHours Float?
  gymId        String
  branchId     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model TrainerSalary {
  id           String    @id @default(uuid())
  trainerId    String    @unique
  fixedSalary  Float     @default(0)
  commissionPt Float     @default(0) // Rate per PT session
  gymId        String
  branchId     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model PtCommission {
  id           String    @id @default(uuid())
  trainerId    String
  sessionId    String?   // PtSession reference
  amount       Float
  date         DateTime  @default(now())
  gymId        String
  branchId     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Payroll {
  id           String    @id @default(uuid())
  trainerId    String
  month        Int       // 1 to 12
  year         Int
  fixedSalary  Float     @default(0)
  commissions  Float     @default(0)
  incentives   Float     @default(0)
  totalAmount  Float
  status       String    @default("Pending") // Pending, Paid
  paymentDate  DateTime?
  gymId        String
  branchId     String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Ticket {
  id          String   @id @default(uuid())
  subject     String
  category    String
  status      String   @default("pending") // pending, resolved
  gymId       String
  branchId    String?
  creatorId   String   // The user who created the ticket
  creatorName String
  creatorRole String
  messages    TicketMessage[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([gymId, status])
  @@index([creatorId])
}

model TicketMessage {
  id         String   @id @default(uuid())
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId   String
  senderName String
  senderRole String
  message    String
  createdAt  DateTime @default(now())

  @@index([ticketId])
}
