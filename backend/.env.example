# ==========================================================================
# GYM-CRM / FitPrime backend environment configuration (TEMPLATE)
# Copy this file to .env and fill in real values. NEVER commit the real .env.
#
# SECURITY: before going to production, ROTATE any secrets that were ever
# checked into the repo or shared (JWT secret, DB password, SMTP keys,
# Razorpay keys). Generate a fresh JWT secret with:
#     node scripts/generateSecret.js
# ==========================================================================

# --- Database ---
# Neon (PostgreSQL) connection string. Use the pooled (pooler) endpoint in prod.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# --- Server & Environment ---
PORT=5000
# Set to "production" for launch. In production CORS only allows CORS_ORIGINS
# and mock Razorpay is disabled.
NODE_ENV=development
CLIENT_URL=http://localhost:5173
# Comma-separated list of allowed browser origins in production, e.g.
#   CORS_ORIGINS=https://app.fitprime.in,https://admin.fitprime.in,https://gym-crm-iota.vercel.app
CORS_ORIGINS=https://gym-crm-iota.vercel.app

# --- Authentication ---
# REQUIRED. Generate with:  node scripts/generateSecret.js
# The server refuses to boot if this is missing or set to a placeholder.
JWT_SECRET=

# --- Payments (Razorpay) ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Email Notifications (SMTP) ---
# Works with Resend, Gmail, SendGrid, etc.
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
FROM_NAME="FitPrime"
FROM_EMAIL=

# --- WhatsApp Notifications (optional) ---
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
