{
  "expo": {
    "name": "FitPrime",
    "slug": "fitprime",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fitprime",
    "userInterfaceStyle": "dark",
    "ios": {
      "icon": "./assets/expo.icon",
      "infoPlist": {
        "NSCameraUsageDescription": "FitPrime needs camera access to scan gym QR codes for check-in",
        "NSLocationWhenInUseUsageDescription": "FitPrime needs your location to verify you are at the gym during check-in"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#6C5CE7",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "CAMERA",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ],
      "package": "com.sanjaipandian.fitprime"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "FitPrime needs camera access to scan gym QR codes for check-in"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "FitPrime needs your location to verify you are at the gym during check-in"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0A0A1A",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-sharing",
      [
        "expo-image-picker",
        {
          "photosPermission": "FitPrime needs access to your photos to upload gym images."
        }
      ],
      "sentry-expo"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
